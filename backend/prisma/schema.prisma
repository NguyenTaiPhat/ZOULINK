datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Link {
  id           String   @id @default(cuid())
  slug         String   @unique
  url          String
  clicks       Int      @default(0)
  createdAt    DateTime @default(now())
  lastAccessed DateTime?
}
